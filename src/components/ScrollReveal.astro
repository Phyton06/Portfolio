---
export interface Props {
  delay?: number;
  class?: string;
}

const { delay = 0 } = Astro.props;
---

<div class="reveal {Astro.props.class ?? ''}" data-reveal-delay={delay} data-astro-transition-persist>
  <slot />
</div>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  [data-animations="paused"] .reveal,
  [data-animations="paused"] .reveal.visible {
    opacity: 1;
    transform: none;
    transition: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const DELAY_STEP = 120;
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.revealDelay || '0', 10) * DELAY_STEP;
          setTimeout(() => el.classList.add('visible'), delay);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
