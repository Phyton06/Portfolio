---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<section class="py-16" data-od-id="project-grid">
  <h2 class="text-2xl md:text-3xl font-bold mb-2">Proyectos destacados</h2>
  <p class="text-(--fg-muted) mb-8">Una selección de los proyectos más recientes.</p>

  {
    projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            slug={project.id}
          />
        ))}
      </div>
    ) : (
      <p class="text-(--fg-muted) text-center py-12">No hay proyectos destacados por el momento.</p>
    )
  }
</section>
