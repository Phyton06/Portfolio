---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
}

const { title, description, tags, slug } = Astro.props;
---

<article class="group relative bg-(--surface) rounded-xl border border-(--border) p-6 hover:border-(--accent)/40 transition-all duration-300">
  <a href={`/projects/${slug}`} class="block no-underline">
    <h3 class="text-xl font-semibold mb-2 text-(--fg) group-hover:text-(--accent) transition-colors">
      {title}
    </h3>
    <p class="text-sm text-(--fg-muted) mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-(--accent)/10 text-(--accent) font-medium">
          {tag}
        </span>
      ))}
    </div>
  </a>
</article>
